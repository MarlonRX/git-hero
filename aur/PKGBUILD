# Maintainer: Marlon Ramirez <mramirezce14@gmail.com>
pkgname=gith
pkgver=0.2.0
pkgrel=1
pkgdesc="Fast and visual TUI for managing Git, written in Rust with Ratatui"
arch=('x86_64' 'aarch64')
url="https://github.com/MarlonRX/git-hero"
license=('MIT')
depends=('git')
makedepends=('cargo' 'rust')
optdepends=()
provides=('gith')
conflicts=('gith' 'git-hero')
source=("$pkgname-$pkgver.tar.gz::https://github.com/MarlonRX/git-hero/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('REPLACE_WITH_ACTUAL_SHA256')

prepare() {
    cd "$pkgname-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd "$pkgname-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_HOME="$srcdir/cargo-home"
    cargo build --release --frozen
}

check() {
    cd "$pkgname-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_HOME="$srcdir/cargo-home"
    cargo test --release --frozen || true
}

package() {
    cd "$pkgname-$pkgver"
    install -Dm755 "target/release/gith" "$pkgdir/usr/bin/gith"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}